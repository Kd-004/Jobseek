@model JobPortal.Models.JobSeeker

@{
    ViewData["Title"] = Model.Id == 0 ? "Add Job Seeker" : "Edit Job Seeker";
    Layout = "~/Views/Shared/MyLayout.cshtml";
}

<div class="theme-page jobseeker-page">

    <!-- Background Glow -->
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <div class="container py-5">

        <!-- Hero -->

        <div class="text-center mb-5">

            <span class="eyebrow-badge px-4 py-2 rounded-pill">

                <i class="bi bi-person-plus me-2"></i>

                Job Seeker

            </span>

            <h1 class="display-3 fw-bold text-white mt-4">

                @(Model.Id == 0 ? "Add Job Seeker" : "Edit Job Seeker")

            </h1>

            <p class="text-light-70 fs-4">

                Add a new job seeker to your system.

            </p>

        </div>

        <!-- Card -->

        <div class="row justify-content-center">

            <div class="col-xl-10 col-lg-11">

                <div class="glass-card p-5">

                    <form asp-action="Upsert"
                          method="post"
                          enctype="multipart/form-data">

                        <input asp-for="Id" hidden />

                        <div class="row g-4">
                            <!-- Full Name -->

                            <div class="col-md-6">

                                <label asp-for="FullName" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-person"></i>
                                    </span>

                                    <input asp-for="FullName"
                                           class="form-control"
                                           placeholder="Enter full name" />

                                </div>

                                <span asp-validation-for="FullName" class="text-danger"></span>

                            </div>


                            <!-- Email -->

                            <div class="col-md-6">

                                <label asp-for="Email" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-envelope"></i>
                                    </span>

                                    <input asp-for="Email"
                                           class="form-control"
                                           placeholder="Enter email" />

                                </div>

                                <span asp-validation-for="Email" class="text-danger"></span>

                            </div>
                            <!-- Phone -->

                            <div class="col-md-6">

                                <label asp-for="Phone" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-telephone"></i>
                                    </span>

                                    <input asp-for="Phone"
                                           class="form-control"
                                           placeholder="Enter phone number" />

                                </div>

                                <span asp-validation-for="Phone" class="text-danger"></span>

                            </div>


                            <!-- Password -->

                            <div class="col-md-6">

                                <label asp-for="Password" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-lock"></i>
                                    </span>

                                    <input asp-for="Password"
                                           type="password"
                                           class="form-control"
                                           placeholder="Enter password" />

                                </div>

                                <span asp-validation-for="Password"
                                      class="text-danger"></span>

                            </div>
                            <!-- DOB -->

                            <div class="col-md-6">

                                <label asp-for="DateOfBirth" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-calendar3"></i>

                                    </span>

                                    <input asp-for="DateOfBirth"
                                           type="date"
                                           class="form-control"
                                           min="1980-01-01"
                                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />

                                </div>

                                <span asp-validation-for="DateOfBirth"
                                      class="text-danger"></span>

                            </div>


                            <!-- Gender -->

                            <div class="col-md-6">

                                <label asp-for="Gender" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-gender-ambiguous"></i>

                                    </span>

                                    <select asp-for="Gender"
                                            class="form-select">

                                        <option value="">-- Select Gender --</option>

                                        <option>Male</option>

                                        <option>Female</option>

                                        <option>Other</option>

                                    </select>

                                </div>

                                <span asp-validation-for="Gender"
                                      class="text-danger"></span>

                            </div>
                            <!-- Address -->

                            <div class="col-md-6">

                                <label asp-for="Address" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-geo-alt"></i>
                                    </span>

                                    <input asp-for="Address"
                                           class="form-control"
                                           placeholder="Enter address" />

                                </div>

                            </div>


                            <!-- City -->

                            <div class="col-md-6">

                                <label asp-for="City" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-buildings"></i>
                                    </span>

                                    <input asp-for="City"
                                           class="form-control"
                                           placeholder="Enter city" />

                                </div>

                            </div>
                            <!-- State -->

                            <div class="col-md-6">

                                <label asp-for="State" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-map"></i>
                                    </span>

                                    <input asp-for="State"
                                           class="form-control"
                                           placeholder="Enter state" />

                                </div>

                            </div>


                            <!-- Country -->

                            <div class="col-md-6">

                                <label asp-for="Country" class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">
                                        <i class="bi bi-globe"></i>
                                    </span>

                                    <input asp-for="Country"
                                           class="form-control"
                                           placeholder="Enter country" />

                                </div>

                            </div>
                            <div class="col-12">

                                <label asp-for="CareerObjective" class="form-label text-white"></label>

                                <textarea asp-for="CareerObjective"
                                          rows="4"
                                          class="form-control dark-input"
                                          placeholder="Write your career objective..."></textarea>

                            </div>
                            <div class="col-md-6">

                                <label asp-for="HighestQualification"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-mortarboard"></i>

                                    </span>

                                    <input asp-for="HighestQualification"
                                           class="form-control"
                                           placeholder="Highest Qualification" />

                                </div>

                                <span asp-validation-for="HighestQualification"
                                      class="text-danger"></span>

                            </div>


                            <div class="col-md-6">

                                <label asp-for="Experience"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-briefcase"></i>

                                    </span>

                                    <input asp-for="Experience"
                                           class="form-control"
                                           placeholder="Years of Experience" />

                                </div>

                            </div>
                            <div class="col-md-6">

                                <label asp-for="CurrentSalary"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        ₹

                                    </span>

                                    <input asp-for="CurrentSalary"
                                           class="form-control"
                                           placeholder="Current Salary" />

                                </div>

                            </div>


                            <div class="col-md-6">

                                <label asp-for="ExpectedSalary"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        ₹

                                    </span>

                                    <input asp-for="ExpectedSalary"
                                           class="form-control"
                                           placeholder="Expected Salary" />

                                </div>

                            </div>
                            <div class="col-12">

                                <label asp-for="Skills"
                                       class="form-label text-white"></label>

                                <textarea asp-for="Skills"
                                          rows="3"
                                          class="form-control dark-input"
                                          placeholder="C#, ASP.NET Core, SQL, HTML, CSS..."></textarea>

                            </div>
                            <div class="col-md-6">

                                <label asp-for="LinkedIn"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-linkedin"></i>

                                    </span>

                                    <input asp-for="LinkedIn"
                                           class="form-control"
                                           placeholder="LinkedIn Profile URL" />

                                </div>

                            </div>


                            <div class="col-md-6">

                                <label asp-for="GitHub"
                                       class="form-label text-white"></label>

                                <div class="input-group custom-input">

                                    <span class="input-group-text">

                                        <i class="bi bi-github"></i>

                                    </span>

                                    <input asp-for="GitHub"
                                           class="form-control"
                                           placeholder="GitHub Profile URL" />

                                </div>

                            </div>
                            <div class="col-md-6">

                                <label asp-for="ProfileImageFile"
                                       class="form-label text-white"></label>

                                <input asp-for="ProfileImageFile"
                                       class="form-control dark-file-input" />

                            </div>


                            <div class="col-md-6">

                                <label asp-for="ResumeUpload"
                                       class="form-label text-white"></label>

                                <input asp-for="ResumeUpload"
                                       class="form-control dark-file-input" />

                            </div>
                            <div class="col-12 text-center mt-4">

                                <button type="submit"
                                        class="btn btn-gradient-primary px-5 py-3">

                                    <i class="bi bi-floppy me-2"></i>

                                    @(Model.Id == 0 ? "Add Job Seeker" : "Update Job Seeker")

                                </button>

                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

@section Scripts{

        <partial name="_ValidationScriptsPartial" />

}
