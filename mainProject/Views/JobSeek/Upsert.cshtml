@model JobPortal.Models.JobSeeker

@{
    ViewData["Title"] = Model.Id == 0 ? "Add Job Seeker" : "Edit Job Seeker";
    Layout = "~/Views/Shared/MyLayout.cshtml";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Upsert" asp-controller="JobSeek" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="ProfileImage" />
    <input type="hidden" asp-for="ResumeFile" />
    <input type="hidden" asp-for="CreatedDate" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div>
        <label asp-for="FullName"></label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Phone"></label>
        <input asp-for="Phone" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

   <div>
    <label asp-for="DateOfBirth" class="form-label text-light-50"></label>
    <input type="date" asp-for="DateOfBirth" class="form-control dark-input"
           min="1980-01-01"
           max="@DateTime.Now.AddYears(-18).ToString("yyyy-MM-dd")"
           value="@(Model.DateOfBirth != default ? Model.DateOfBirth.ToString("yyyy-MM-dd") : "")" />
    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
</div>

    <div>
        <label asp-for="Gender"></label>
        <select asp-for="Gender">
            <option value="">-- Select Gender --</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>
            <option value="Other">Other</option>
        </select>
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Address"></label>
        <input asp-for="Address" />
    </div>

    <div>
        <label asp-for="City"></label>
        <input asp-for="City" />
    </div>

    <div>
        <label asp-for="State"></label>
        <input asp-for="State" />
    </div>

    <div>
        <label asp-for="Country"></label>
        <input asp-for="Country" />
    </div>

    <div>
        <label asp-for="ProfileImageFile"></label>
        <input asp-for="ProfileImageFile" type="file" accept="image/*" />
        @if (!string.IsNullOrEmpty(Model.ProfileImage))
        {
            <div>
                <img src="@Model.ProfileImage" alt="Profile Image" width="100" />
            </div>
        }
    </div>

    <div>
        <label asp-for="CareerObjective"></label>
        <textarea asp-for="CareerObjective" rows="4"></textarea>
    </div>

    <div>
        <label asp-for="HighestQualification"></label>
        <input asp-for="HighestQualification" />
        <span asp-validation-for="HighestQualification" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Experience"></label>
        <input asp-for="Experience" type="number" min="0" max="50" />
        <span asp-validation-for="Experience" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="CurrentSalary"></label>
        <input asp-for="CurrentSalary" type="number" step="1000" min="8000" />
        <span asp-validation-for="CurrentSalary" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="ExpectedSalary"></label>
        <input asp-for="ExpectedSalary" type="number" step="1000" min="10000" />
        <span asp-validation-for="ExpectedSalary" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Skills"></label>
        <input asp-for="Skills" placeholder="e.g. C#, ASP.NET, SQL" />
    </div>

    <div>
        <label asp-for="ResumeUpload"></label>
        <input asp-for="ResumeUpload" type="file" accept=".pdf,.doc,.docx" />
        @if (!string.IsNullOrEmpty(Model.ResumeFile))
        {
            <div>
                <a href="@Model.ResumeFile" target="_blank">View Current Resume</a>
            </div>
        }
    </div>

    <div>
        <label asp-for="LinkedIn"></label>
        <input asp-for="LinkedIn" />
        <span asp-validation-for="LinkedIn" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="GitHub"></label>
        <input asp-for="GitHub" />
        <span asp-validation-for="GitHub" class="text-danger"></span>
    </div>

    <div>
        <button type="submit">Save</button>
        <a asp-action="Index">Cancel</a>
        <button type="submit"
                class="btn btn-danger"
                formaction="@Url.Action("Delete", "Jobseek")"
                formmethod="post"
                onclick="return confirm('Are you sure you want to delete this profile?');">
            Delete
        </button>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}



<style>
    body {
        background: linear-gradient(135deg, #0a0e27 0%, #0d1b2a 50%, #1b263b 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Roboto, sans-serif;
        color: #e8e4d8;
    }

    h2 {
        text-align: center;
        color: #f5d78e;
        text-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
        margin: 30px 0;
        letter-spacing: 1px;
        font-weight: 600;
    }

    form {
        max-width: 800px;
        margin: 0 auto 50px auto;
        padding: 35px;
        background: rgba(20, 30, 55, 0.45);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(212, 175, 55, 0.25);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(245, 215, 142, 0.08);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px 25px;
    }

        form div {
            display: flex;
            flex-direction: column;
        }

            /* full width fields */
            form div:has(textarea),
            form div:has(> button),
            form > div:last-of-type {
                grid-column: 1 / -1;
            }

    label {
        font-size: 13px;
        font-weight: 600;
        color: #d4af37;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    input,
    select,
    textarea {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 10px;
        padding: 11px 14px;
        color: #f5f2e8;
        font-size: 14px;
        outline: none;
        transition: all 0.25s ease;
        backdrop-filter: blur(6px);
    }

        input::placeholder,
        textarea::placeholder {
            color: rgba(232, 228, 216, 0.4);
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: #f5d78e;
            background: rgba(212, 175, 55, 0.1);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
        }

        select option {
            background: #0d1b2a;
            color: #f5f2e8;
        }

    textarea {
        resize: vertical;
        min-height: 100px;
    }

    input[type="file"] {
        padding: 8px;
        cursor: pointer;
    }

        input[type="file"]::file-selector-button {
            background: rgba(212, 175, 55, 0.2);
            border: 1px solid rgba(212, 175, 55, 0.45);
            color: #f5d78e;
            padding: 6px 14px;
            border-radius: 6px;
            cursor: pointer;
            margin-right: 10px;
            transition: background 0.2s ease;
        }

            input[type="file"]::file-selector-button:hover {
                background: rgba(212, 175, 55, 0.35);
            }

    img {
        margin-top: 10px;
        border-radius: 10px;
        border: 1px solid rgba(212, 175, 55, 0.35);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.35);
    }

    a {
        color: #e8c766;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
            color: #f5d78e;
        }

    .text-danger {
        color: #ff8080;
        font-size: 12px;
        margin-top: 4px;
    }

    button[type="submit"] {
        background: linear-gradient(135deg, #b8860b, #d4af37, #f5d78e);
        border: none;
        color: #0d1b2a;
        font-weight: 700;
        padding: 12px 30px;
        border-radius: 10px;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        margin-right: 12px;
    }

        button[type="submit"]:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(212, 175, 55, 0.6);
        }

    /* buttons/cancel link row */
    form > div:last-of-type {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 10px;
    }

    @@media (max-width: 700px) {
        form {
            grid-template-columns: 1fr;
            margin: 0 15px 40px 15px;
        }
    }
</style>