@model JobPortal.Models.JobSeeker
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
    ViewData["Title"] = "Job Seeker Profile";
}

@if (Model == null)
{
    <div class="alert alert-info">
        <h4>No Profile Found</h4>
        <p>You haven't created your job seeker profile yet.</p>
        <a asp-action="Upsert" class="btn btn-primary">
            Create Profile
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h3>@Model.FullName</h3>
            <a asp-action="Upsert" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit Profile
            </a>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 text-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="~/@Model.ProfileImage" alt="@Model.FullName" class="rounded-circle" style="width:150px;height:150px;object-fit:cover;" />
                    }
                    else
                    {
                        <i class="bi bi-person-circle" style="font-size:150px;"></i>
                    }
                </div>
                <div class="col-md-9">
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @Model.Phone</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToString("dd MMM yyyy")</p>
                    <p><strong>Gender:</strong> @Model.Gender</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>City:</strong> @Model.City, @Model.State, @Model.Country</p>
                </div>
            </div>

            <hr />

            <p><strong>Career Objective:</strong></p>
            <p>@Model.CareerObjective</p>

            <div class="row">
                <div class="col-md-4">
                    <p><strong>Highest Qualification:</strong> @Model.HighestQualification</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Experience:</strong> @Model.Experience yrs</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Expected Salary:</strong> @(Model.ExpectedSalary.HasValue? Model.ExpectedSalary.Value.ToString("C0") : "-")</p>
                </div>
            </div>

            <p><strong>Skills:</strong> @Model.Skills</p>

            <p>
                <strong>Resume:</strong>
                @if (!string.IsNullOrEmpty(Model.ResumeFile))
                {
                    <a href="~/@Model.ResumeFile" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-file-earmark-text"></i> View Resume
                    </a>
                }
                else
                {
                    <span class="text-muted">Not uploaded</span>
                }
            </p>

            <p>
                <strong>LinkedIn:</strong>
                @if (!string.IsNullOrEmpty(Model.LinkedIn))
                {
                    <a href="@Model.LinkedIn" target="_blank">@Model.LinkedIn</a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </p>

            <p>
                <strong>GitHub:</strong>
                @if (!string.IsNullOrEmpty(Model.GitHub))
                {
                    <a href="@Model.GitHub" target="_blank">@Model.GitHub</a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </p>
        </div>
    </div>
}