@model JobPortal.Models.JobSeeker
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
    ViewData["Title"] = "Job Seeker Profile";
}
@if (Model == null)
{
    <div class="alert alert-info">
        <h4>No Profile Found</h4>
        <p>You haven't created your job seeker profile yet.</p>
        <a asp-action="Upsert" class="btn btn-primary">
            Create Profile
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h3>@Model.FullName</h3>
            <a asp-action="Upsert" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit Profile
            </a>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 text-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="~/@Model.ProfileImage" alt="@Model.FullName" class="rounded-circle" style="width:150px;height:150px;object-fit:cover;" />
                    }
                    else
                    {
                        <i class="bi bi-person-circle" style="font-size:150px;"></i>
                    }
                </div>
                <div class="col-md-9">
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @Model.Phone</p>
                    <p><strong>Date of Birth:</strong> @Model.DateOfBirth.ToString("dd MMM yyyy")</p>
                    <p><strong>Gender:</strong> @Model.Gender</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>City:</strong> @Model.City, @Model.State, @Model.Country</p>
                </div>
            </div>
            <hr />
            <p><strong>Career Objective:</strong></p>
            <p>@Model.CareerObjective</p>
            <div class="row">
                <div class="col-md-4">
                    <p><strong>Highest Qualification:</strong> @Model.HighestQualification</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Experience:</strong> @Model.Experience yrs</p>
                </div>
                <div class="col-md-4">
                    <p><strong>Expected Salary:</strong> @(Model.ExpectedSalary.HasValue? Model.ExpectedSalary.Value.ToString("C0") : "-")</p>
                </div>
            </div>
            <p><strong>Skills:</strong> @Model.Skills</p>
            <p>
                <strong>Resume:</strong>
                @if (!string.IsNullOrEmpty(Model.ResumeFile))
                {
                    <a href="~/@Model.ResumeFile" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-file-earmark-text"></i> View Resume
                    </a>
                }
                else
                {
                    <span class="text-muted">Not uploaded</span>
                }
            </p>
            <p>
                <strong>LinkedIn:</strong>
                @if (!string.IsNullOrEmpty(Model.LinkedIn))
                {
                    <a href="@Model.LinkedIn" target="_blank">@Model.LinkedIn</a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </p>
            <p>
                <strong>GitHub:</strong>
                @if (!string.IsNullOrEmpty(Model.GitHub))
                {
                    <a href="@Model.GitHub" target="_blank">@Model.GitHub</a>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </p>
        </div>
    </div>
}

<style>
    body {
        background: linear-gradient(135deg, #0a0e27 0%, #0d1b2a 50%, #1b263b 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Roboto, sans-serif;
        color: #e8e4d8;
    }

    .alert-info {
        background: rgba(20, 30, 55, 0.45);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 14px;
        color: #f5f2e8;
        padding: 30px;
        max-width: 600px;
        margin: 40px auto;
        text-align: center;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    }

        .alert-info h4 {
            color: #f5d78e;
            text-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
            margin-bottom: 12px;
        }

        .alert-info p {
            color: #cfc9b8;
            margin-bottom: 20px;
        }

    .card {
        max-width: 900px;
        margin: 30px auto;
        background: rgba(20, 30, 55, 0.45);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(212, 175, 55, 0.25);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(245, 215, 142, 0.08);
        overflow: hidden;
    }

    .card-header {
        background: rgba(212, 175, 55, 0.08);
        border-bottom: 1px solid rgba(212, 175, 55, 0.25);
        padding: 20px 28px;
    }

        .card-header h3 {
            color: #f5d78e;
            text-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
            margin: 0;
            letter-spacing: 0.5px;
            font-weight: 600;
        }

    .card-body {
        padding: 30px;
    }

        .card-body p {
            color: #e8e4d8;
            font-size: 15px;
            margin-bottom: 14px;
        }

            .card-body p strong {
                color: #d4af37;
                display: inline-block;
                min-width: 130px;
                text-transform: uppercase;
                font-size: 12px;
                letter-spacing: 0.5px;
                font-weight: 600;
            }

    hr {
        border: none;
        border-top: 1px solid rgba(212, 175, 55, 0.2);
        margin: 24px 0;
    }

    i.bi-person-circle {
        color: rgba(212, 175, 55, 0.4);
    }

    img.rounded-circle {
        border: 2px solid rgba(212, 175, 55, 0.4);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.35);
    }

    a {
        color: #e8c766;
        text-decoration: none;
    }

        a:hover {
            text-decoration: underline;
            color: #f5d78e;
        }

    .text-muted {
        color: rgba(232, 228, 216, 0.45) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2b6fff, #4fa3ff);
        border: none;
        color: #ffffff;
        font-weight: 600;
        padding: 10px 24px;
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(64, 145, 255, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(64, 145, 255, 0.6);
            color: #ffffff;
        }

    .btn-warning {
        background: linear-gradient(135deg, #b8860b, #d4af37, #f5d78e);
        border: none;
        color: #0d1b2a;
        font-weight: 700;
        padding: 8px 20px;
        border-radius: 10px;
        box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(212, 175, 55, 0.6);
            color: #0d1b2a;
        }

    .btn-outline-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(212, 175, 55, 0.35);
        color: #e8c766;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .btn-outline-secondary:hover {
            background: rgba(212, 175, 55, 0.15);
            border-color: #f5d78e;
            color: #f5d78e;
        }

    @@media (max-width: 700px) {
        .card, .alert-info {
            margin: 20px 15px;
        }

        .card-body p strong {
            min-width: auto;
            display: block;
        }
    }
</style>