@model mainProject.Models.Company
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
}

<div class="theme-page py-5">
    <div class="glow glow-1"></div>
    <div class="glow glow-2 glow-gold"></div>

    <div class="container position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="text-center mb-4">
                    <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                        <i class="bi bi-building me-1"></i> Company Profile
                    </span>
                    <h1 class="fw-bold text-white display-6">
                        @(Model.Id == 0 ? "Add Company" : "Update Company")
                    </h1>
                </div>

                <div class="card glass-card">
                    <div class="card-body p-4 p-md-5">

                        <form asp-action="Upsert" method="post" enctype="multipart/form-data" asp-controller="Company">

                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="UserId" />

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    <label asp-for="CompanyName" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="CompanyName" class="form-control dark-input" />
                                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Email" class="form-label text-light-50"></label>
                                    <input type="email" asp-for="Email" class="form-control dark-input" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Phone" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="Phone" class="form-control dark-input" />
                                    <span asp-validation-for="Phone" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-light-50">Company Logo</label>
                                    <input type="file" name="logoFile" class="form-control dark-input dark-file-input" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Website" class="form-label text-light-50"></label>
                                    <input type="url" asp-for="Website" class="form-control dark-input" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Industry" class="form-label text-light-50"></label>
                                    <select asp-for="Industry" class="form-select search-select">
                                        <option value="">Select Industry</option>
                                        <option>Information Technology</option>
                                        <option>Healthcare</option>
                                        <option>Education</option>
                                        <option>Finance</option>
                                        <option>Manufacturing</option>
                                        <option>Retail</option>
                                        <option>Marketing</option>
                                        <option>Other</option>
                                    </select>
                                </div>

                                <div class="col-12 mb-3">
                                    <label asp-for="Description" class="form-label text-light-50"></label>
                                    <textarea asp-for="Description" class="form-control dark-input" rows="4"></textarea>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Address" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="Address" class="form-control dark-input" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="City" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="City" class="form-control dark-input" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="State" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="State" class="form-control dark-input" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Country" class="form-label text-light-50"></label>
                                    <input type="text" asp-for="Country" class="form-control dark-input" />
                                </div>

                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-3">

                                @if (Model.Id == 0)
                                {
                                    <button type="submit" class="btn btn-gradient-primary px-4">
                                        <i class="bi bi-check-circle me-1"></i> Save Company
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-gold px-4">
                                        <i class="bi bi-arrow-repeat me-1"></i> Update Company
                                    </button>
                                }

                                <button type="submit"
                                        class="btn btn-outline-danger-glass px-4"
                                        formaction="@Url.Action("Delete", "Company")"
                                        formmethod="post"
                                        onclick="return confirm('Are you sure you want to delete this company?');">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </button>

                                <a asp-action="Index" class="btn btn-outline-glass px-4">
                                    <i class="bi bi-arrow-left me-1"></i> Back to List
                                </a>

                            </div>
                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}