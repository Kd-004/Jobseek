@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
}
@if (Model == null)
{
    <div class="alert alert-info">
        <h4>No Company Found</h4>
        <p>You haven't created your company profile yet.</p>

        <a asp-action="Upsert" class="btn btn-primary">
            Create Company
        </a>
    </div>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>@Model.CompanyName</h3>
        </div>

        <div class="card-body">
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
            <p><strong>Industry:</strong> @Model.Industry</p>
            <p><strong>City:</strong> @Model.City</p>

            <a asp-action="Upsert" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit Company
            </a>
        </div>
    </div>
}