@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    body {
        background: #F8FAFC;
    }

    .hero-section {
        background: linear-gradient(135deg,#0F172A,#2563EB);
    }

    .hero-image {
        max-height: 480px;
        animation: float 4s ease-in-out infinite;
    }

    .search-section {
        margin-top: -70px;
        position: relative;
        z-index: 100;
    }

    .card {
        border-radius: 20px;
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,.15);
        }

    .btn-primary {
        background: linear-gradient(45deg,#2563EB,#3B82F6);
        border: none;
    }

    .btn-warning {
        border: none;
    }

  



</style>

<!-- Hero Section -->
<!-- ================= HERO SECTION ================= -->
<section class="hero-section position-relative overflow-hidden">

    <div class="container py-5">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <span class="badge bg-warning text-dark px-3 py-2 mb-3 rounded-pill">
                    #1 Job Portal
                </span>

                <h1 class="display-3 fw-bold text-white">
                    Find Your <span class="text-warning">Dream Job</span> Today
                </h1>

                <p class="lead text-light mt-4">
                    Discover thousands of verified job opportunities from top
                    companies across India. Build your career with confidence.
                </p>

                <div class="mt-4">

                    <a asp-controller="Job"
                       asp-action="Index"
                       class="btn btn-warning btn-lg px-4 rounded-pill me-3 shadow">

                        <i class="bi bi-search me-2"></i>
                        Browse Jobs

                    </a>

                    <a asp-area="Identity"
                       asp-page="/Account/Register"
                       class="btn btn-outline-light btn-lg px-4 rounded-pill">

                        <i class="bi bi-person-plus me-2"></i>
                        Register

                    </a>

                </div>

                <div class="row mt-5">

                    <div class="col-4 text-center">

                        <h2 class="fw-bold text-warning">10K+</h2>
                        <p class="text-light">Jobs</p>

                    </div>

                    <div class="col-4 text-center">

                        <h2 class="fw-bold text-warning">500+</h2>
                        <p class="text-light">Companies</p>

                    </div>

                    <div class="col-4 text-center">

                        <h2 class="fw-bold text-warning">30K+</h2>
                        <p class="text-light">Candidates</p>

                    </div>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/images/job.png"
                     class="img-fluid hero-image">

            </div>

        </div>

    </div>

    <!-- Bottom Wave -->

    <svg xmlns="http://www.w3.org/2000/svg"
         viewBox="0 0 1440 320">

        <path fill="#F8FAFC"
              fill-opacity="1"
              d="M0,224L60,213.3C120,203,240,181,360,176C480,171,600,181,720,197.3C840,213,960,235,1080,229.3C1200,224,1320,192,1380,176L1440,160L1440,320L0,320Z">
        </path>

    </svg>

</section>

<!-- Search -->
<section class="search-section">

    <div class="container">

        <div class="card border-0 shadow-lg rounded-4">

            <div class="card-body p-4">

                <form>

                    <div class="row g-3">

                        <div class="col-md-4">

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-search"></i>
                                </span>

                                <input class="form-control"
                                       placeholder="Job title or keyword">

                            </div>

                        </div>

                        <div class="col-md-3">

                            <div class="input-group">

                                <span class="input-group-text bg-white">
                                    <i class="bi bi-geo-alt"></i>
                                </span>

                                <input class="form-control"
                                       placeholder="Location">

                            </div>

                        </div>

                        <div class="col-md-3">

                            <select class="form-select">

                                <option>Choose Category</option>
                                <option>Software</option>
                                <option>Marketing</option>
                                <option>Finance</option>
                                <option>Healthcare</option>

                            </select>

                        </div>

                        <div class="col-md-2">

                            <button class="btn btn-primary w-100 rounded-pill">

                                Search

                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- Categories -->

<section class="py-5 bg-light">

    <div class="container">

        <div class="text-center mb-5">
            <span class="badge bg-primary px-3 py-2 rounded-pill">
                Explore
            </span>

            <h2 class="fw-bold mt-3">
                Popular Categories
            </h2>

            <p class="text-muted">
                Explore opportunities from top industries
            </p>
        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">

                <div class="card category-card border-0 shadow">

                    <div class="card-body text-center">

                        <div class="category-icon bg-primary">
                            <i class="bi bi-laptop"></i>
                        </div>

                        <h5 class="mt-4">Software</h5>

                        <span class="badge bg-primary">
                            350 Jobs
                        </span>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card category-card border-0 shadow">

                    <div class="card-body text-center">

                        <div class="category-icon bg-success">
                            <i class="bi bi-graph-up-arrow"></i>
                        </div>

                        <h5 class="mt-4">Marketing</h5>

                        <span class="badge bg-success">
                            180 Jobs
                        </span>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card category-card border-0 shadow">

                    <div class="card-body text-center">

                        <div class="category-icon bg-warning">
                            <i class="bi bi-cash-stack"></i>
                        </div>

                        <h5 class="mt-4">Finance</h5>

                        <span class="badge bg-warning text-dark">
                            150 Jobs
                        </span>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card category-card border-0 shadow">

                    <div class="card-body text-center">

                        <div class="category-icon bg-danger">
                            <i class="bi bi-hospital"></i>
                        </div>

                        <h5 class="mt-4">Healthcare</h5>

                        <span class="badge bg-danger">
                            220 Jobs
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

