            </div>

        </div>

</section>

<!-- Statistics -->

<section class="py-5 statistics-section">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <h1>10K+</h1>

                <p>Jobs Posted</p>

            </div>

            <div class="col-md-3">

                <h1>500+</h1>

                <p>Companies</p>

            </div>

            <div class="col-md-3">

                <h1>30K+</h1>

                <p>Candidates</p>

            </div>

            <div class="col-md-3">

                <h1>98%</h1>

                <p>Success Rate</p>

            </div>

        </div>

    </div>

</section>

