@{
    ViewData["Title"] = "UserDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #05070f;
    }

    .glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(130px);
        opacity: 0.35;
        pointer-events: none;
    }

    /* ================= HERO ================= */
    .hero-section {
        position: relative;
        overflow: hidden;
        background: linear-gradient(160deg, #05070f 0%, #0b1330 45%, #101a3d 85%, #0b1330 100%);
    }

    .hero-glow-1 {
        width: 550px;
        height: 550px;
        background: #2b5cff;
        top: -180px;
        left: -120px;
    }

    .hero-glow-2 {
        width: 450px;
        height: 450px;
        background: #f5a623;
        opacity: 0.15;
        bottom: -150px;
        right: -100px;
    }

    .eyebrow-badge {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #ffd98a;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        backdrop-filter: blur(6px);
    }

    .text-gold {
        color: #f5b942 !important;
    }

    .text-light-50 {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    .text-light-70 {
        color: rgba(255, 255, 255, 0.8) !important;
    }

    .hero-image {
        max-height: 460px;
        filter: drop-shadow(0 25px 45px rgba(0, 0, 0, 0.5));
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-16px);
        }
    }

    .btn-gold {
        background: linear-gradient(135deg, #f5c15c 0%, #e08e2e 100%);
        border: none;
        color: #1a1200;
        font-weight: 700;
        transition: transform 0.2s ease, filter 0.2s ease;
    }

        .btn-gold:hover {
            transform: translateY(-2px);
            filter: brightness(1.08);
            color: #1a1200;
        }

    .btn-outline-glass {
        border: 1px solid rgba(255, 255, 255, 0.35);
        color: #fff;
        font-weight: 600;
        transition: background 0.2s ease, transform 0.2s ease;
    }

        .btn-outline-glass:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            transform: translateY(-2px);
        }

    .stat-number {
        color: #f5b942;
    }

    /* ================= GLASS CARD SYSTEM ================= */
    .glass-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.035);
        backdrop-filter: blur(16px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

        .glass-card:hover {
            transform: translateY(-6px);
            border-color: rgba(109, 140, 255, 0.35);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
        }

    /* ================= SEARCH ================= */
    .search-section {
        margin-top: -55px;
        position: relative;
        z-index: 100;
    }

    .search-input, .search-select {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        color: #fff !important;
    }

        .search-input::placeholder {
            color: rgba(255, 255, 255, 0.45);
        }

        .search-input:focus, .search-select:focus {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border-color: #3b6dff !important;
            box-shadow: 0 0 0 0.2rem rgba(59, 109, 255, 0.25) !important;
            color: #fff !important;
        }

        .search-select option {
            background-color: #101a3d;
            color: #fff;
        }

    .input-group-text-dark {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-right: none;
        color: rgba(255, 255, 255, 0.55);
    }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #3b6dff 0%, #1a3aad 100%);
        border: none;
        color: #fff;
        font-weight: 600;
        transition: filter 0.2s ease, transform 0.2s ease;
    }

        .btn-gradient-primary:hover {
            filter: brightness(1.15);
            color: #fff;
            transform: translateY(-2px);
        }

    /* ================= SECTIONS ================= */
    .section-dark {
        background: #05070f;
        position: relative;
    }

    .section-alt {
        background: #080b18;
        position: relative;
    }

    .category-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        font-size: 1.6rem;
        color: #fff;
    }

    .icon-blue {
        background: linear-gradient(135deg,#3b6dff,#1a3aad);
        box-shadow: 0 0 20px rgba(59,109,255,.35);
    }

    .icon-green {
        background: linear-gradient(135deg,#22c55e,#15803d);
        box-shadow: 0 0 20px rgba(34,197,94,.3);
    }

    .icon-gold {
        background: linear-gradient(135deg,#f5c15c,#e08e2e);
        box-shadow: 0 0 20px rgba(245,193,92,.3);
    }

    .icon-red {
        background: linear-gradient(135deg,#f87171,#b91c1c);
        box-shadow: 0 0 20px rgba(248,113,113,.3);
    }

    .job-card .badge-soft-success {
        background: rgba(34,197,94,.15);
        color: #4ade80;
    }

    .job-card .badge-soft-light {
        background: rgba(255,255,255,.08);
        color: rgba(255,255,255,.75);
    }

    .job-card .badge-soft-info {
        background: rgba(59,130,246,.15);
        color: #7cb0ff;
    }

    .cta-section {
        background: linear-gradient(135deg, #101a3d, #1a3aad);
        position: relative;
        overflow: hidden;
    }
</style>

<!-- ================= HERO SECTION ================= -->
<section class="hero-section">
    <div class="glow hero-glow-1"></div>
    <div class="glow hero-glow-2"></div>

    <div class="container py-5 position-relative">
        <div class="row align-items-center">

            <div class="col-lg-6">
                <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                    <i class="bi bi-award-fill me-1"></i> #1 Job Portal
                </span>

                <h1 class="display-4 fw-bold text-white">
                    Find Your <span class="text-gold">Dream Job</span> Today
                </h1>

                <p class="lead text-light-50 mt-4">
                    Discover thousands of verified job opportunities from top
                    companies across India. Build your career with confidence.
                </p>

                <div class="mt-4">
                    <a asp-controller="Job" asp-action="Index" class="btn btn-gold btn-lg px-4 rounded-pill me-3 shadow">
                        <i class="bi bi-search me-2"></i>Browse Jobs
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-glass btn-lg px-4 rounded-pill">
                        <i class="bi bi-person-plus me-2"></i>Register
                    </a>
                </div>

                <div class="row mt-5">
                    <div class="col-4 text-center">
                        <h2 class="fw-bold stat-number">10K+</h2>
                        <p class="text-light-50 mb-0">Jobs</p>
                    </div>
                    <div class="col-4 text-center">
                        <h2 class="fw-bold stat-number">500+</h2>
                        <p class="text-light-50 mb-0">Companies</p>
                    </div>
                    <div class="col-4 text-center">
                        <h2 class="fw-bold stat-number">30K+</h2>
                        <p class="text-light-50 mb-0">Candidates</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 text-center">
                <img src="~/images/job.png" class="img-fluid hero-image" />
            </div>

        </div>
    </div>
</section>

<!-- ================= SEARCH ================= -->
<section class="search-section">
    <div class="container">
        <div class="card glass-card">
            <div class="card-body p-4">
                <form>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text input-group-text-dark">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input class="form-control search-input" placeholder="Job title or keyword">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group">
                                <span class="input-group-text input-group-text-dark">
                                    <i class="bi bi-geo-alt"></i>
                                </span>
                                <input class="form-control search-input" placeholder="Location">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select search-select">
                                <option>Choose Category</option>
                                <option>Software</option>
                                <option>Marketing</option>
                                <option>Finance</option>
                                <option>Healthcare</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-gradient-primary w-100 rounded-pill">Search</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- ================= CATEGORIES ================= -->
<section class="py-5 mt-4 section-dark">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge rounded-pill eyebrow-badge px-3 py-2">
                <i class="bi bi-grid-fill me-1"></i> Explore
            </span>
            <h2 class="fw-bold mt-3 text-white">Popular Categories</h2>
            <p class="text-light-50">Explore opportunities from top industries</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card glass-card">
                    <div class="card-body text-center py-4">
                        <div class="category-icon icon-blue"><i class="bi bi-laptop"></i></div>
                        <h5 class="mt-4 text-white">Software</h5>
                        <span class="badge job-card badge-soft-info">350 Jobs</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card glass-card">
                    <div class="card-body text-center py-4">
                        <div class="category-icon icon-green"><i class="bi bi-graph-up-arrow"></i></div>
                        <h5 class="mt-4 text-white">Marketing</h5>
                        <span class="badge job-card badge-soft-success">180 Jobs</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card glass-card">
                    <div class="card-body text-center py-4">
                        <div class="category-icon icon-gold"><i class="bi bi-cash-stack"></i></div>
                        <h5 class="mt-4 text-white">Finance</h5>
                        <span class="badge bg-warning text-dark">150 Jobs</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card glass-card">
                    <div class="card-body text-center py-4">
                        <div class="category-icon icon-red"><i class="bi bi-hospital"></i></div>
                        <h5 class="mt-4 text-white">Healthcare</h5>
                        <span class="badge bg-danger">220 Jobs</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= LATEST JOBS ================= -->
<section class="py-5 section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge rounded-pill eyebrow-badge px-3 py-2">
