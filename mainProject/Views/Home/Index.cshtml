            </span>
            <h2 class="fw-bold mt-3 text-white">Latest Jobs</h2>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="card glass-card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-white">ASP.NET Core Developer</h5>
                            <span class="badge job-card badge-soft-success">Full Time</span>
                        </div>
                        <p class="text-gold fw-semibold mb-1">ABC Technologies</p>
                        <p class="text-light-50"><i class="bi bi-geo-alt"></i> Chandigarh</p>
                        <p>
                            <span class="badge job-card badge-soft-light">₹8-12 LPA</span>
                            <span class="badge job-card badge-soft-info">2+ Years</span>
