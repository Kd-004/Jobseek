                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card glass-card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-white">MERN Stack Developer</h5>
                            <span class="badge job-card badge-soft-success">Full Time</span>
                        </div>
                        <p class="text-gold fw-semibold mb-1">XYZ Solutions Pvt. Ltd.</p>
                        <p class="text-light-50"><i class="bi bi-geo-alt"></i> Mohali</p>
                        <p>
                            <span class="badge job-card badge-soft-light">₹8-12 LPA</span>
                            <span class="badge job-card badge-soft-info">2+ Years</span>
                        </p>
                        <hr style="border-color: rgba(255,255,255,.08)">
                        <a href="#" class="btn btn-gradient-primary rounded-pill w-100">Apply Now</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card glass-card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold text-white">DBA</h5>
                            <span class="badge job-card badge-soft-success">Full Time</span>
                        </div>
                        <p class="text-gold fw-semibold mb-1">RiseUp Softwares Pvt. Ltd.</p>
                        <p class="text-light-50"><i class="bi bi-geo-alt"></i> Delhi</p>
                        <p>
                            <span class="badge job-card badge-soft-light">₹8-12 LPA</span>
                            <span class="badge job-card badge-soft-info">2+ Years</span>
                        </p>
                        <hr style="border-color: rgba(255,255,255,.08)">
                        <a href="#" class="btn btn-gradient-primary rounded-pill w-100">Apply Now</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ================= STATISTICS ================= -->
<section class="py-5 section-dark">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3">
                <h1 class="fw-bold stat-number">10K+</h1>
                <p class="text-light-50">Jobs Posted</p>
            </div>
            <div class="col-md-3">
                <h1 class="fw-bold stat-number">500+</h1>
                <p class="text-light-50">Companies</p>
            </div>
            <div class="col-md-3">
                <h1 class="fw-bold stat-number">30K+</h1>
                <p class="text-light-50">Candidates</p>
            </div>
            <div class="col-md-3">
                <h1 class="fw-bold stat-number">98%</h1>
                <p class="text-light-50">Success Rate</p>
            </div>
        </div>
    </div>
</section>

<!-- ================= WHY CHOOSE US ================= -->
<section class="py-5 section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-white">Why Choose JobSeek?</h2>
            <p class="text-light-50">Helping professionals find better careers.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card glass-card h-100">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-lightning-charge-fill text-gold display-3"></i>
                        <h4 class="mt-3 text-white">Fast Hiring</h4>
                        <p class="text-light-50">Get hired faster with verified employers.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card glass-card h-100">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-patch-check-fill text-success display-3"></i>
                        <h4 class="mt-3 text-white">Verified Companies</h4>
                        <p class="text-light-50">Trusted employers with genuine jobs.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card glass-card h-100">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-briefcase-fill" style="color:#6d8cff" class="display-3"></i>
                        <h4 class="mt-3 text-white">Career Growth</h4>
                        <p class="text-light-50">Grow your career with thousands of opportunities.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ================= CALL TO ACTION ================= -->
<section class="py-5 text-center cta-section">
    <div class="container position-relative">
        <h2 class="fw-bold text-white">Ready to Build Your Career?</h2>
        <p class="text-light-70 mt-3">Create your free account and start applying today.</p>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-gold btn-lg rounded-pill px-5 mt-3">
            Create Free Account
        </a>
    </div>
</section>