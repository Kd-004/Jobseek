@model mainProject.ViewModels.UserDashboard

@{
    ViewData["Title"] = "User Dashboard";
    Layout = "~/Views/Shared/MyLayout.cshtml";
}

<div class="theme-page container-fluid py-4">
    <!-- Header -->
    <div class="theme-page container-fluid py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h2 class="fw-bold text-white">
                    Welcome back, @User.Identity?.Name
                </h2>

                <p class="text-secondary mb-0">
                    Here's what's happening with your job search today.
                </p>
            </div>

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="text-decoration-none">
                            Home
                        </a>
                    </li>

                    <li class="breadcrumb-item active text-secondary">
                        Dashboard
                    </li>
                </ol>
            </nav>

        </div>


        <!-- Statistics -->

        <div class="row g-4 mb-4">

            <!-- Applied -->

            <div class="col-lg-3 col-md-6">

                <div class="card glass-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h1 class="fw-bold text-white">
                                    @Model.AppliedJobs
                                </h1>

                                <h5 class="text-secondary">
                                    Applied Jobs
                                </h5>

                            </div>

                            <i class="bi bi-file-earmark-text display-5 text-warning dashboard-icon"></i>

                        </div>

                    </div>

                    <div class="card-footer bg-transparent">

                        <a asp-controller="ApplyJob"
                           asp-action="MyApplications"
                           class="text-decoration-none">

                            View Applications
                            <i class="bi bi-link-45deg"></i>

                        </a>

                    </div>

                </div>

            </div>


            <!-- Accepted -->

            <div class="col-lg-3 col-md-6">

                <div class="card glass-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h1 class="fw-bold text-white">
                                    @Model.AcceptedJobs
                                </h1>

                                <h5 class="text-secondary">
                                    Accepted Jobs
                                </h5>

                            </div>

                            <i class="bi bi-check-circle-fill display-5 text-success dashboard-icon"></i>

                        </div>

                    </div>

                    <div class="card-footer bg-transparent">

                        <a asp-controller="ApplyJob"
                           asp-action="MyApplications"
                           class="text-decoration-none">

                            View Accepted
                            <i class="bi bi-link-45deg"></i>

                        </a>

                    </div>

                </div>

            </div>


            <!-- Rejected -->

            <div class="col-lg-3 col-md-6">

                <div class="card glass-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h1 class="fw-bold text-white">
                                    @Model.RejectedJobs
                                </h1>

                                <h5 class="text-secondary">
                                    Rejected Jobs
                                </h5>

                            </div>

                            <i class="bi bi-x-circle-fill display-5 text-danger dashboard-icon"></i>

                        </div>

                    </div>

                    <div class="card-footer bg-transparent">

                        <a asp-controller="ApplyJob"
                           asp-action="MyApplications"
                           class="text-decoration-none">

                            View Rejected
                            <i class="bi bi-link-45deg"></i>

                        </a>

                    </div>

                </div>

            </div>


            <!-- Profile -->

            <div class="col-lg-3 col-md-6">

                <div class="card glass-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between">

                            <div>

                                <h1 class="fw-bold text-white">
                                    @Model.ProfileCompletion%
                                </h1>

                                <h5 class="text-secondary">
                                    Profile Completion
                                </h5>

                            </div>

                            <i class="bi bi-person-circle display-5 text-info dashboard-icon"></i>

                        </div>

                    </div>

                    <div class="card-footer bg-transparent">

                        <a asp-controller="JobSeek"
                           asp-action="Index"
                           class="text-decoration-none">

                            Update Profile
                            <i class="bi bi-link-45deg"></i>

                        </a>

                    </div>

                </div>

            </div>

        </div>


        <!-- Quick Actions -->

        <div class="card glass-card mb-4">

            <div class="card-body">

                <div class="row align-items-center">

                    <div class="col-md-4">

                        <h5 class="fw-bold mb-0">
                            QUICK ACTIONS
                        </h5>

                    </div>

                    <div class="col-md-8 text-md-end">

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-primary me-2">

                            <i class="bi bi-search"></i>

                            Find Jobs

                        </a>

                        <a asp-controller="ApplyJob"
                           asp-action="MyApplications"
                           class="btn btn-outline-light me-2">

                            <i class="bi bi-check-circle"></i>

                            Accepted

                        </a>

                        <a asp-controller="ApplyJob"
                           asp-action="MyApplications"
                           class="btn btn-outline-light me-2">

                            <i class="bi bi-file-earmark-text"></i>

                            My Applications

                        </a>

                        <a asp-controller="JobSeek"
                           asp-action="Index"
                           class="btn btn-outline-light">

                            <i class="bi bi-person"></i>

                            My Profile

                        </a>

                    </div>

                </div>

            </div>

        </div>
    <!-- Recommended Jobs & Recent Applications -->
        <!-- Recommended Jobs & Recent Applications -->

        <div class="row g-4 mb-4">

            <!-- Recommended Jobs -->

            <div class="col-lg-7">

                <div class="card glass-card h-100">

                    <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center">

                        <h4 class="mb-0">
                            <i class="bi bi-briefcase me-2"></i>
                            Recommended Jobs
                        </h4>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="text-decoration-none">

                            View All
                            <i class="bi bi-arrow-right"></i>

                        </a>

                    </div>

                    <div class="card-body">

                        @if (Model.RecommendedJobs.Any())
                        {
                            @foreach (var job in Model.RecommendedJobs)
                            {
                                <div class="border rounded-3 p-3 mb-3">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div>

                                            <h5 class="fw-bold text-white mb-2">
                                                @job.JobTitle
                                            </h5>

                                            <div class="text-secondary small mb-2">

                                                <i class="bi bi-geo-alt"></i>
                                                @job.Location

                                                <span class="mx-2">•</span>

                                                @job.EmploymentType

                                            </div>

                                            <div class="text-warning fw-semibold">

                                                ₹ @job.Salary

                                            </div>

                                        </div>

                                        <div>

                                            <a asp-controller="ApplyJob"
                                               asp-action="JobDetails"
                                               asp-route-id="@job.JobId"
                                               class="btn btn-primary">

                                                Apply Now

                                            </a>

                                        </div>

                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">

                                <i class="bi bi-search display-2 text-secondary"></i>

                                <h5 class="mt-3 text-secondary">

                                    No Recommended Jobs

                                </h5>

                            </div>
                        }

                    </div>

                </div>

            </div>

            <!-- Recent Applications -->

            <div class="col-lg-5">

                <div class="card glass-card h-100">

                    <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center">

                        <h4 class="mb-0">

                            <i class="bi bi-clock-history me-2"></i>

                            Recent Applications

                        </h4>

                        <span class="badge bg-primary">

                            @Model.RecentApplications.Count

                        </span>

                    </div>

                    <div class="card-body">

                        @if (Model.RecentApplications.Any())
                        {
                            @foreach (var application in Model.RecentApplications)
                            {

                                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">

                                    <div>

                                        <h6 class="fw-bold text-white mb-1">

                                            @application.Job.JobTitle

                                        </h6>

                                        <small class="text-secondary">

                                            Applied :
                                            @application.AppliedDate.ToString("dd MMM yyyy")

                                        </small>

                                    </div>

                                    <div>

                                        @if (application.Status == "Accepted")
                                        {
                                            <span class="badge bg-success">
                                                Accepted
                                            </span>
                                        }
                                        else if (application.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger">
                                                Rejected
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Pending
                                            </span>
                                        }

                                    </div>

                                </div>

                            }
                        }
                        else
                        {
                            <div class="text-center py-5">

                                <i class="bi bi-person-x display-2 text-secondary"></i>

                                <h5 class="mt-3 text-secondary">

                                    No Applications Yet

                                </h5>

                                <p class="text-secondary">

                                    Start applying for jobs today.

                                </p>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    <!-- Recent Notifications -->
        <!-- Recent Notifications -->

        <div class="card glass-card mb-4">

            <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center">

                <h4 class="mb-0">
                    <i class="bi bi-bell me-2 text-warning"></i>
                    Recent Notifications
                </h4>

                <span class="badge bg-warning text-dark">
                    @Model.RecentApplications.Count
                </span>

            </div>

            <div class="card-body">

                @if (Model.RecentApplications.Any())
                {
                    @foreach (var application in Model.RecentApplications.Take(5))
                    {
                        <div class="d-flex align-items-start mb-4 pb-3 border-bottom">

                            <div class="flex-shrink-0">

                                @if (application.Status == "Accepted")
                                {
                                    <div class="bg-success bg-opacity-10 rounded-circle p-2">
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    </div>
                                }
                                else if (application.Status == "Rejected")
                                {
                                    <div class="bg-danger bg-opacity-10 rounded-circle p-2">
                                        <i class="bi bi-x-circle-fill text-danger"></i>
                                    </div>
                                }
                                else
                                {
                                    <div class="bg-warning bg-opacity-10 rounded-circle p-2">
                                        <i class="bi bi-hourglass-split text-warning"></i>
                                    </div>
                                }

                            </div>

                            <div class="ms-3 flex-grow-1">

                                <h6 class="fw-semibold text-white mb-1">
                                    @application.Job.JobTitle
                                </h6>

                                @if (application.Status == "Accepted")
                                {
                                    <p class="text-secondary mb-1">
                                        Congratulations! Your application has been accepted.
                                    </p>
                                }
                                else if (application.Status == "Rejected")
                                {
                                    <p class="text-secondary mb-1">
                                        Your application was not selected this time.
                                    </p>
                                }
                                else
                                {
                                    <p class="text-secondary mb-1">
                                        Your application is currently under review.
                                    </p>
                                }

                                <small class="text-secondary">
                                    @application.AppliedDate.ToString("dd MMM yyyy")
                                </small>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">

                        <i class="bi bi-bell-slash display-3 text-secondary"></i>

                        <h5 class="mt-3 text-secondary">
                            No Notifications
                        </h5>

                        <p class="text-secondary">
                            Your latest application updates will appear here.
                        </p>

                    </div>
                }

            </div>

        </div>

    </div>

@section Scripts{
        <partial name="_ValidationScriptsPartial" />
}
