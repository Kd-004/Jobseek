<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - mainProject</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mainProject.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-theme sticky-top">
            <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <i class="bi bi-briefcase-fill me-1"></i>JobSeek
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbar">

                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Dashboard"
                               asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Jobs"
                               asp-action="Index">Jobs</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Company"
                               asp-action="Index">Companies</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Privacy">About</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <partial name="_LoginPartial" />

                        <a asp-controller="Jobs"
                           asp-action="Post"
                           class="btn btn-navbar-cta">
                            Post a Job
                        </a>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer footer-theme mt-auto">
        <div class="container text-center py-3">
            &copy; 2026 - JobSeek -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>