<!DOCTYPE html>
<html lang="en">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>JobSeek | Dashboard</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#0b1330" />

    <meta name="title" content="JobSeek | Dashboard" />
    <meta name="author" content="JobSeek" />
    <meta name="description" content="Employer and job seeker dashboard for JobSeek job portal." />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@fontsource/source-sans-3@@5.0.12/index.css"
          integrity="sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q="
          crossorigin="anonymous"
          media="print"
          onload="this.media = 'all'" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css"
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
          crossorigin="anonymous" />

    <link rel="stylesheet" href="~/assets/css/adminlte.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/apexcharts@3.37.1/dist/apexcharts.css"
          integrity="sha256-4MX+61mt9NVvvuPjUWdUdyfZfxSB1/Rf9WtqRHgG5S0="
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/jsvectormap@1.5.3/dist/css/jsvectormap.min.css"
          integrity="sha256-+uGLJmmTKOqBr+2E6KDYs/NRsHxSkONXFHUL0fy2O/4="
          crossorigin="anonymous" />

    <!-- JobSeek shared theme — MUST load last so it overrides AdminLTE defaults -->
    <link rel="stylesheet" href="~/css/site-theme.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
       <nav class="app-header navbar navbar-expand navbar-theme">
    <div class="container-fluid">

        <!-- Left: sidebar toggle + brand -->
        <ul class="navbar-nav align-items-center">
            <li class="nav-item">
                <a class="nav-link topbar-icon-btn" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-flex align-items-center ms-2">
                <a href="/" class="topbar-brand">
                    <i class="bi bi-briefcase-fill"></i>
                    <span>JobSeek</span>
                </a>
            </li>
        </ul>

        <!-- Right: search, fullscreen, user -->
        <ul class="navbar-nav ms-auto align-items-center">

            <li class="nav-item">
                <a class="nav-link topbar-icon-btn" data-widget="navbar-search" href="#" role="button">
                    <i class="bi bi-search"></i>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link topbar-icon-btn" href="#" data-lte-toggle="fullscreen">
                    <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                    <i data-lte-icon="minimize" class="bi bi-fullscreen-exit d-none"></i>
                </a>
            </li>

            <li class="nav-item dropdown user-menu ms-1">
                <a href="#" class="nav-link dropdown-toggle topbar-user" data-bs-toggle="dropdown">
                    <img src="./assets/img/user2-160x160.jpg" class="user-image rounded-circle shadow" alt="User Image" />
                    <span class="d-none d-md-inline">@(User.Identity.IsAuthenticated ? User.Identity.Name : "Guest")</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                    <li class="user-header user-header-theme">
                        <img src="./assets/img/user2-160x160.jpg" class="rounded-circle shadow" alt="User Image" />
                        <p>@(User.Identity.IsAuthenticated ? User.Identity.Name : "Guest")</p>
                    </li>
                    <li class="user-footer">
                        <a href="#" class="btn btn-outline-glass btn-sm">Profile</a>
                        <a href="#" class="btn btn-outline-danger-glass btn-sm float-end">Sign out</a>
                    </li>
                </ul>
            </li>

        </ul>
    </div>
</nav>

        <aside class="app-sidebar sidebar-theme shadow" data-bs-theme="dark">

            <div class="sidebar-brand">
                <a href="/" class="brand-link">
                    <i class="bi bi-briefcase-fill brand-icon"></i>
                    <span class="brand-text fw-bold">JobSeek</span>
                </a>
            </div>

            <div class="sidebar-wrapper">
                <nav class="mt-2" aria-label="Main navigation">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" data-accordion="false" id="navigation">
                        <li class="nav-item">
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/AdminDashboard" class="nav-link active">
                                    <i class="nav-icon bi bi-speedometer2"></i>
                                    <p>Dashboard</p>
                                </a>
                                <a href="/company" class="nav-link">
                                    <i class="nav-icon bi bi-building"></i>
                                    <p>Company Profile</p>
                                </a>
                                <a href="/job" class="nav-link">
                                    <i class="nav-icon bi bi-briefcase"></i>
                                    <p>Jobs</p>
                                </a>
                            }

                            @if (User.IsInRole("User"))
                            {
                                <a href="/UserDashboard" class="nav-link active">
                                    <i class="nav-icon bi bi-speedometer2"></i>
                                    <p>Dashboard</p>
                                </a>
                                <a href="/JobSeek" class="nav-link">
                                    <i class="nav-icon bi bi-person"></i>
                                    <p>My Profile</p>
                                </a>
                                <a href="/ApplyJob" class="nav-link">
                                    <i class="nav-icon bi bi-briefcase"></i>
                                    <p>Jobs</p>
                                </a>
                            }

                        <li class="nav-item">
                            <a asp-controller="ApplyJob"
                               asp-action="Applications"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ApplyJob"
                                                       && ViewContext.RouteData.Values["Action"]?.ToString() == "Applications"
                                                       ? "active" : "")">

                                <i class="nav-icon bi bi-file-earmark-person"></i>
                                <p>Applications</p>
                            </a>


                        <li class="nav-item">
                            <a asp-controller="ApplyJob"
                               asp-action="MyApplications"
                               class="nav-link">
                                <i class="bi bi-file-earmark-check"></i>
                                <p>My Applications</p>
                            </a>
                        </li>

                        
                    </ul>
                </nav>

                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home")"
                      method="post">

                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </button>

                </form>

            </div>
        </aside>

        <main role="main" class="main-content theme-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer footer-theme">
        <div class="float-end d-none d-sm-inline">JobSeek &mdash; Find your next opportunity</div>
        <strong>
            Copyright &copy; 2014-2026&nbsp;
            <a href="/">JobSeek.io</a>.
        </strong>
        All rights reserved.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
    <script src="~/assets/js/adminlte.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>