@model mainProject.Models.JobWithCompany
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
    ViewData["Title"] = Model.Job.JobTitle;
}

<div class="theme-page py-5">
    <div class="glow glow-1"></div>
    <div class="glow glow-2 glow-gold"></div>

    <div class="container position-relative">

        <!-- Header -->
        <div class="card glass-card mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                    <div>
                        <span class="badge badge-soft-info me-2">@Model.Job.Category</span>
                        <span class="badge badge-soft-success">@Model.Job.Status</span>

                        <h2 class="fw-bold text-white mt-3 mb-2">@Model.Job.JobTitle</h2>

                        <p class="text-light-50 mb-1">
                            <i class="bi bi-building me-1"></i>
                            <strong class="text-white fw-semibold">Company:</strong> @Model.CompanyName
                        </p>

                        <p class="text-light-50 mb-0">
                            <i class="bi bi-geo-alt-fill me-1"></i>
                            <strong class="text-white fw-semibold">Location:</strong> @Model.Job.Location
                        </p>
                    </div>

                    <div class="text-end">
                        <h3 class="text-gold fw-bold mb-0">
                            ₹@Model.Job.Salary.ToString("N0")
                        </h3>
                        <small class="text-light-50">Annual Salary</small>
                    </div>

                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Job Description -->
            <div class="col-lg-8">
                <div class="card glass-card h-100">
                    <div class="card-header">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-file-earmark-text me-2"></i>Job Description
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-light-50 mb-0" style="white-space: pre-line;">@Model.Job.JobDescription</p>
                    </div>
                </div>
            </div>

            <!-- Job Overview -->
            <div class="col-lg-4">
                <div class="card glass-card">
                    <div class="card-header">
                        <h5 class="mb-0 text-white">Job Overview</h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase">Employment Type</span>
                            <span class="text-white text-end">@Model.Job.EmploymentType</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase">Experience</span>
                            <span class="text-white text-end">@Model.Job.Experience</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase">Qualification</span>
                            <span class="text-white text-end">@Model.Job.Qualification</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase">Vacancies</span>
                            <span class="text-white text-end">@Model.Job.Vacancy</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase">Posted Date</span>
                            <span class="text-white text-end">@Model.Job.PostedDate.ToString("dd MMM yyyy")</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2">
                            <span class="text-light-50 small text-uppercase">Last Date to Apply</span>
                            <span class="fw-bold text-end" style="color:#f87171;">
                                @Model.Job.LastDateToApply.ToString("dd MMM yyyy")
                            </span>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Job Highlights -->
        <div class="row g-4 mt-1">

            <div class="col-md-3">
                <div class="card glass-card text-center h-100">
                    <div class="card-body p-4">
                        <div class="icon-circle icon-blue mb-3">
                            <i class="bi bi-briefcase-fill"></i>
                        </div>
                        <h6 class="text-white mb-1">Category</h6>
                        <p class="text-light-50 mb-0">@Model.Job.Category</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card glass-card text-center h-100">
                    <div class="card-body p-4">
                        <div class="icon-circle icon-red mb-3">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h6 class="text-white mb-1">Location</h6>
                        <p class="text-light-50 mb-0">@Model.Job.Location</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card glass-card text-center h-100">
                    <div class="card-body p-4">
                        <div class="icon-circle icon-green mb-3">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <h6 class="text-white mb-1">Salary</h6>
                        <p class="text-light-50 mb-0">₹@Model.Job.Salary.ToString("N0")</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card glass-card text-center h-100">
                    <div class="card-body p-4">
                        <div class="icon-circle icon-gold mb-3">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h6 class="text-white mb-1">Vacancies</h6>
                        <p class="text-light-50 mb-0">@Model.Job.Vacancy</p>
                    </div>
                </div>
            </div>

        </div>

        <!-- Buttons -->
        <div class="text-center mt-5">

            <form asp-controller="JobSeek" asp-action="Upsert" method="get">
                <input type="hidden" name="jobId" value="@Model.Job.JobId" />

                <button type="submit" class="btn btn-gold btn-lg px-5 me-3">
                    <i class="bi bi-send-fill me-1"></i>
                    Apply Now
                </button>
            </form>>

            <a  asp-controller="ApplyJob" asp-action="Details" class="btn btn-outline-glass btn-lg">
                <i class="bi bi-arrow-left me-1"></i> Back to Jobs
            </a>

        </div>

    </div>
</div>