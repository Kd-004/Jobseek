@model mainProject.Models.Company
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
    ViewData["Title"] = Model.CompanyName;
}

<div class="theme-page py-5">
    <div class="glow glow-1"></div>
    <div class="glow glow-2 glow-gold"></div>

    <div class="container position-relative">

        <!-- Company Header -->
        <div class="card glass-card mb-4">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center g-4">

                    <div class="col-auto">
                        @if (!string.IsNullOrEmpty(Model.Logo))
                        {
                            <img src="@Model.Logo" alt="@Model.CompanyName logo"
                                 class="rounded-circle border border-2"
                                 style="width:96px;height:96px;object-fit:cover;border-color: rgba(245,193,92,.35) !important;" />
                        }
                        else
                        {
                            <div class="icon-circle icon-circle-accent" style="width:96px;height:96px;font-size:2.25rem;">
                                <i class="bi bi-building"></i>
                            </div>
                        }
                    </div>

                    <div class="col">
                        <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-2">
                            <i class="bi bi-briefcase me-1"></i>@Model.Industry
                        </span>
                        <h1 class="fw-bold text-white mb-1">@Model.CompanyName</h1>
                        <p class="text-light-50 mb-0">
                            <i class="bi bi-geo-alt me-1"></i>@Model.City, @Model.State, @Model.Country
                        </p>
                    </div>

                    <div class="col-12 col-md-auto">
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <a href="@Model.Website" target="_blank" rel="noopener" class="btn btn-outline-glass w-100">
                                <i class="bi bi-globe me-1"></i> Visit Website
                            </a>
                        }
                    </div>

                </div>
            </div>
        </div>

        <div class="row g-4">

            <!-- Main content -->
            <div class="col-lg-8">

                <div class="card glass-card mb-4">
                    <div class="card-header">
                        <h5 class="fw-bold text-white mb-0">
                            <i class="bi bi-info-circle me-2"></i>About @Model.CompanyName
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-light-50 mb-0" style="white-space: pre-line;">@Model.Description</p>
                    </div>
                </div>

                @if (ViewBag.CompanyJobs != null && ((IEnumerable<mainProject.Models.Job>)ViewBag.CompanyJobs).Any())
                {
                    <div class="card glass-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-white mb-0">
                                <i class="bi bi-briefcase-fill me-2"></i>Open Positions
                            </h5>
                            <span class="badge badge-soft-info">
                                @(((IEnumerable<mainProject.Models.Job>)ViewBag.CompanyJobs).Count()) jobs
                            </span>
                        </div>
                        <div class="card-body p-4">
                            @foreach (var job in (IEnumerable<mainProject.Models.Job>)ViewBag.CompanyJobs)
                            {
                                <div class="d-flex justify-content-between align-items-center py-3 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                                    <div>
                                        <h6 class="text-white fw-semibold mb-1">@job.JobTitle</h6>
                                        <p class="text-light-50 small mb-0">
                                            <i class="bi bi-geo-alt me-1"></i>@job.Location
                                            <span class="mx-2">&middot;</span>
                                            <i class="bi bi-clock-history me-1"></i>@job.Experience
                                        </p>
                                    </div>
                                    <a asp-controller="ApplyJob" asp-action="Apply" asp-route-jobId="@job.JobId"
                                       class="btn btn-gradient-primary btn-sm">
                                        View & Apply
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card glass-card text-center">
                        <div class="card-body p-5">
                            <i class="bi bi-briefcase display-4 text-light-50"></i>
                            <p class="text-light-50 mt-3 mb-0">No open positions at this company right now.</p>
                        </div>
                    </div>
                }

            </div>

            <!-- Sidebar: contact details -->
            <div class="col-lg-4">
                <div class="card glass-card">
                    <div class="card-header">
                        <h5 class="fw-bold text-white mb-0">
                            <i class="bi bi-person-lines-fill me-2"></i>Contact Info
                        </h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase"><i class="bi bi-envelope me-1"></i>Email</span>
                            <span class="text-white text-truncate ms-2" style="max-width:150px;" title="@Model.Email">@Model.Email</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase"><i class="bi bi-telephone me-1"></i>Phone</span>
                            <span class="text-white">@Model.Phone</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom" style="border-color: rgba(255,255,255,.08) !important;">
                            <span class="text-light-50 small text-uppercase"><i class="bi bi-building me-1"></i>Industry</span>
                            <span class="text-white">@Model.Industry</span>
                        </div>

                        <div class="py-2">
                            <span class="text-light-50 small text-uppercase d-block mb-1"><i class="bi bi-geo-alt me-1"></i>Address</span>
                            <span class="text-white">
                                @Model.Address, @Model.City,<br />@Model.State, @Model.Country
                            </span>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </div>
</div>
