@foreach (var item in Model)
{
    <div class="theme-page p-5" style="height:100vh;">
    <tr>
        <td>@item.Job.JobTitle</td>
        <td>@item.Company.CompanyName</td>
        <td>@item.AppliedDate.ToString("dd MMM yyyy")</td>

        <td>
            @if (item.Status == "Accepted")
            {
                <span class="badge bg-success">
                    <i class="bi bi-check-circle-fill"></i> Accepted
                </span>
            }
            else if (item.Status == "Rejected")
            {
                <span class="badge bg-danger">
                    <i class="bi bi-x-circle-fill"></i> Rejected
                </span>
            }
            else
            {
                <span class="badge bg-warning text-dark">
                    <i class="bi bi-clock-history"></i> Pending
                </span>
            }
        </td>
    </tr>

    @if (item.Status == "Accepted")
    {
        <tr>
            <td colspan="4">
                <div class="alert alert-success mt-2">
                    <i class="bi bi-trophy-fill"></i>
                    Congratulations! Your application has been accepted. The company will contact you soon.
                </div>
            </td>
        </tr>
    }

    @if (item.Status == "Rejected")
    {
        <tr>
            <td colspan="4">
                <div class="alert alert-danger mt-2">
                    <i class="bi bi-x-circle-fill"></i>
                    Unfortunately, your application was not selected.
                </div>
            </td>
        </tr>
    }
        </div>
}