@model IEnumerable<mainProject.Models.Job>

@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
}
<div class="theme-page py-5" style="height:100vh;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 style="color:white;">Job List</h2>

        @if (ViewBag.HasCompany == true)
        {
            <a asp-action="Upsert" class="btn btn-gradient-primary">
                <i class="bi bi-plus-circle me-1"></i> Post New Job
            </a>
        }
        else
        {
            <a asp-controller="Company" asp-action="Index" class="btn btn-gold" title="Create your company profile first">
                <i class="bi bi-building me-1"></i> Create Company to Post Jobs
            </a>
        }
    </div>

    <table class="table table-bordered table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Job Title</th>
                <th>Category</th>
                <th>Location</th>
                <th>Employment Type</th>
                <th>Experience</th>
                <th>Qualification</th>
                <th>Salary</th>
                <th>Vacancy</th>
                <th>Last Date</th>
                <th>Status</th>
                <th width="180">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.JobTitle</td>
                        <td>@item.Category</td>
                        <td>@item.Location</td>
                        <td>@item.EmploymentType</td>
                        <td>@item.Experience</td>
                        <td>@item.Qualification</td>
                        <td>₹@item.Salary</td>
                        <td>@item.Vacancy</td>
                        <td>@item.LastDateToApply.ToString("dd-MM-yyyy")</td>
                        <td>
                            @if (item.Status == "Open")
                            {
                                <span class="badge bg-success">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                        </td>

                        <td>
                            <a asp-action="Details" asp-route-id="@item.JobId" class="btn btn-info btn-sm">
                                Details
                            </a>

                            <a asp-action="Upsert" asp-route-id="@item.JobId" class="btn btn-warning btn-sm">
                                Edit
                            </a>

                     

                         <form asp-action="Delete" asp-route-id="@item.JobId" method="post" style="display:inline;">
    @Html.AntiForgeryToken()

    <button type="submit"
            class="btn btn-danger btn-sm"
            onclick="return confirm('Are you sure you want to delete this job?');">
        Delete
    </button>
</form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center text-danger">
                        No Jobs Available
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>