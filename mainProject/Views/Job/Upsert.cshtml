@model mainProject.Models.Job
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3>@(Model.JobId == 0 ? "Add Job" : "Update Job")</h3>
        </div>

        <div class="card-body">

            <form asp-action="Upsert" method="post" asp-controller="Job">

                <input type="hidden" asp-for="JobId" />
                <input type="hidden" asp-for="PostedDate" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="CompanyId" class="form-label"></label>
                        <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.CompanyList">
                            <option value="">Select Company</option>
                        </select>
                        <span asp-validation-for="CompanyId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="JobTitle" class="form-label"></label>
                        <input type="text" asp-for="JobTitle" class="form-control" />
                        <span asp-validation-for="JobTitle" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <select asp-for="Category" class="form-select">
                            <option value="">Select Category</option>
                            <option>Information Technology</option>
                            <option>Healthcare</option>
                            <option>Education</option>
                            <option>Finance</option>
                            <option>Manufacturing</option>
                            <option>Retail</option>
                            <option>Marketing</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label"></label>
                        <input type="text" asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="EmploymentType" class="form-label"></label>
                        <select asp-for="EmploymentType" class="form-select">
                            <option value="">Select Employment Type</option>
                            <option>Full-Time</option>
                            <option>Part-Time</option>
                            <option>Contract</option>
                            <option>Internship</option>
                            <option>Remote</option>
                        </select>
                        <span asp-validation-for="EmploymentType" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Experience" class="form-label"></label>
                        <input type="text" asp-for="Experience" class="form-control" placeholder="e.g. 2-4 years" />
                        <span asp-validation-for="Experience" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Qualification" class="form-label"></label>
                        <input type="text" asp-for="Qualification" class="form-control" />
                        <span asp-validation-for="Qualification" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Salary" class="form-label"></label>
                        <input type="number" asp-for="Salary" class="form-control" step="0.01" />
                        <span asp-validation-for="Salary" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Vacancy" class="form-label"></label>
                        <input type="number" asp-for="Vacancy" class="form-control" min="1" max="10000" />
                        <span asp-validation-for="Vacancy" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LastDateToApply" class="form-label"></label>
                        <input type="date" asp-for="LastDateToApply" class="form-control"
                               value="@(Model.LastDateToApply != default ? Model.LastDateToApply.ToString("yyyy-MM-dd") : "")" />
                        <span asp-validation-for="LastDateToApply" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option>Open</option>
                            <option>Closed</option>
                            <option>On Hold</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="JobDescription" class="form-label"></label>
                        <textarea asp-for="JobDescription"
                                  class="form-control"
                                  rows="5"></textarea>
                        <span asp-validation-for="JobDescription" class="text-danger"></span>
                    </div>

                </div>

                <div class="mt-3">

                    @if (Model.JobId == 0)
                    {
                        <button type="submit" class="btn btn-success">
                            Save Job
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-warning">
                            Update Job
                        </button>
                    }
                    <button type="submit"
                            class="btn btn-danger"
                            formaction="@Url.Action("Delete", "Job")"
                            formmethod="post"
                            onclick="return confirm('Are you sure you want to delete this job?');">
                        Delete
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>

                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}