@model mainProject.Models.Job
@{
    Layout = "~/Views/Shared/MyLayout.cshtml";
    ViewData["Title"] = "Job Details";
}

<div class="theme-page py-5">
    <div class="glow glow-1"></div>
    <div class="glow glow-2 glow-gold"></div>

    <div class="container position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-9">

                <div class="text-center mb-4">
                    <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                        <i class="bi bi-briefcase-fill me-1"></i> Job Posting
                    </span>
                    <h1 class="fw-bold text-white display-6">@Model.JobTitle</h1>
                    <div class="mt-2">
                        @if (Model.Status == "Open")
                        {
                            <span class="badge badge-soft-success">Open</span>
                        }
                        else if (Model.Status == "On Hold")
                        {
                            <span class="badge bg-warning text-dark">On Hold</span>
                        }
                        else
                        {
                            <span class="badge badge-soft-light">Closed</span>
                        }
                    </div>
                </div>

                <div class="card glass-card">
                    <div class="card-body p-4 p-md-5">

                        <div class="row">

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Job Title</span>
                                <span class="text-white fs-6">@Model.JobTitle</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Category</span>
                                <span class="text-white fs-6">@Model.Category</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Location</span>
                                <span class="text-white fs-6"><i class="bi bi-geo-alt me-1"></i>@Model.Location</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Employment Type</span>
                                <span class="text-white fs-6">@Model.EmploymentType</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Experience</span>
                                <span class="text-white fs-6">@Model.Experience</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Qualification</span>
                                <span class="text-white fs-6">@Model.Qualification</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Salary</span>
                                <span class="text-gold fw-semibold fs-6">₹@Model.Salary.ToString("N0")</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Vacancy</span>
                                <span class="text-white fs-6">@Model.Vacancy</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Posted Date</span>
                                <span class="text-white fs-6">@Model.PostedDate.ToString("dd MMM yyyy")</span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Last Date to Apply</span>
                                <span class="fw-semibold fs-6" style="color:#f87171;">
                                    @Model.LastDateToApply.ToString("dd MMM yyyy")
                                </span>
                            </div>

                            <div class="col-12 mb-2">
                                <span class="text-light-50 small text-uppercase d-block mb-1">Job Description</span>
                                <p class="text-white fs-6 mb-0" style="white-space: pre-line;">@Model.JobDescription</p>
                            </div>

                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,.08) !important;">
                            <a asp-action="Index" class="btn btn-outline-glass px-4">
                                <i class="bi bi-arrow-left me-1"></i> Back to List
                            </a>
                            <a asp-action="Upsert" asp-route-id="@Model.JobId" class="btn btn-gold px-4">
                                <i class="bi bi-pencil-square me-1"></i> Edit Job
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
