@page
@model RegisterModel
@{
    ViewData["Title"] = "Choose Registration Type";
}

<div class="register-choice-page">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <div class="container position-relative py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <div class="text-center mb-5">
                    <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                        <i class="bi bi-stars me-1"></i> Join JobPortal
                    </span>
                    <h1 class="fw-bold display-5 text-white">Create Your Account</h1>
                    <p class="text-light-50 fs-5 mb-0">
                        Choose how you'd like to get started — you can always add more later.
                    </p>
                </div>

                <div class="row g-4 justify-content-center">

                    <!-- User Card -->
                    <div class="col-md-6 col-lg-5">
                        <div class="card registration-card h-100">
                            <div class="card-body p-5 d-flex flex-column">
                                <div class="icon-circle icon-circle-primary mb-4">
                                    <i class="bi bi-person-workspace"></i>
                                </div>
                                <h3 class="fw-bold mb-2 text-white">Job Seeker</h3>
                                <p class="text-light-50 mb-4">
                                    Search thousands of jobs, apply instantly, upload your
                                    resume and track your applications in one place.
                                </p>

                                <ul class="list-unstyled feature-list mb-4">
                                    <li><i class="bi bi-check-circle-fill me-2"></i>Personalized job matches</li>
                                    <li><i class="bi bi-check-circle-fill me-2"></i>One-click applications</li>
                                    <li><i class="bi bi-check-circle-fill me-2"></i>Application tracking dashboard</li>
                                </ul>

                                <a asp-page="./RegisterUser" class="btn btn-gradient-primary btn-lg w-100 mt-auto">
                                    Register as Job Seeker
                                    <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Admin Card -->
                    <div class="col-md-6 col-lg-5">
                        <div class="card registration-card h-100">
                            <div class="card-body p-5 d-flex flex-column">
                                <div class="icon-circle icon-circle-accent mb-4">
                                    <i class="bi bi-building"></i>
                                </div>
                                <h3 class="fw-bold mb-2 text-white">Admin</h3>
                                <p class="text-light-50 mb-4">
                                    Post jobs, manage applicants, and hire the best talent
                                    for your company — all from a single dashboard.
                                </p>

                                <ul class="list-unstyled feature-list mb-4">
                                    <li><i class="bi bi-check-circle-fill me-2"></i>Unlimited job postings</li>
                                    <li><i class="bi bi-check-circle-fill me-2"></i>Applicant management tools</li>
                                    <li><i class="bi bi-check-circle-fill me-2"></i>Team & company profile</li>
                                </ul>

                                <a asp-page="./RegisterAdmin" class="btn btn-gradient-accent btn-lg w-100 mt-auto">
                                    Register as Admin
                                    <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                </div>

                <p class="text-center text-light-50 mt-5 mb-0">
                    Already have an account?
                    <a asp-page="/Login" class="fw-semibold text-decoration-none login-link">Log in</a>
                </p>

            </div>
        </div>
    </div>
</div>

<style>
    .register-choice-page {
        position: relative;
        min-height: 90vh;
        overflow: hidden;
        background: linear-gradient(160deg, #05070f 0%, #0b1330 45%, #101a3d 75%, #05070f 100%);
    }

    /* soft ambient glow blobs */
    .glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.35;
        pointer-events: none;
    }

    .glow-1 {
        width: 500px;
        height: 500px;
        background: #2b5cff;
        top: -150px;
        left: -100px;
    }

    .glow-2 {
        width: 450px;
        height: 450px;
        background: #1e3a8a;
        bottom: -180px;
        right: -120px;
    }

    .eyebrow-badge {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #cfd8ff;
        font-size: 0.85rem;
        font-weight: 500;
        backdrop-filter: blur(6px);
    }

        .eyebrow-badge i {
            color: #6d8cff;
        }

    .text-light-50 {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    .registration-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.035);
        backdrop-filter: blur(16px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

        .registration-card:hover {
            transform: translateY(-6px);
            border-color: rgba(109, 140, 255, 0.4);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
        }

    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
    }

    .icon-circle-primary {
        background: linear-gradient(135deg, #2b5cff 0%, #12308a 100%);
        color: #fff;
        box-shadow: 0 0 25px rgba(43, 92, 255, 0.4);
    }

    .icon-circle-accent {
        background: linear-gradient(135deg, #4b5563 0%, #111827 100%);
        color: #fff;
        box-shadow: 0 0 25px rgba(75, 85, 99, 0.35);
    }

    .feature-list li {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.75);
        margin-bottom: 0.5rem;
    }

    .feature-list i {
        color: #6d8cff;
    }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #3b6dff 0%, #1a3aad 100%);
        border: none;
        color: #fff;
        font-weight: 600;
        transition: filter 0.2s ease, transform 0.2s ease;
    }

        .btn-gradient-primary:hover {
            filter: brightness(1.15);
            color: #fff;
            transform: translateY(-2px);
        }

    .btn-gradient-accent {
        background: linear-gradient(135deg, #374151 0%, #0f172a 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        font-weight: 600;
        transition: filter 0.2s ease, transform 0.2s ease;
    }

        .btn-gradient-accent:hover {
            filter: brightness(1.3);
            color: #fff;
            transform: translateY(-2px);
        }

    .login-link {
        color: #8ba4ff;
    }

        .login-link:hover {
            color: #b6c6ff;
        }
</style>