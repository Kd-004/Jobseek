@page
@model RegisterUserModel
@{
    ViewData["Title"] = "User Registration";
}

<div class="auth-page">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <div class="container position-relative py-5">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">

                <div class="text-center mb-4">
                    <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                        <i class="bi bi-person-workspace me-1"></i> Job Seeker Account
                    </span>
                    <h1 class="fw-bold text-white display-6">Create Your Account</h1>
                    <p class="text-light-50">Start applying to jobs in minutes.</p>
                </div>

                <div class="card auth-card">
                    <div class="card-body p-4 p-md-5">

                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control dark-input" placeholder="name@example.com" />
                                <label asp-for="Input.Email"></label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control dark-input" placeholder="password" />
                                <label asp-for="Input.Password"></label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-4">
                                <input asp-for="Input.ConfirmPassword" class="form-control dark-input" placeholder="confirm password" />
                                <label asp-for="Input.ConfirmPassword"></label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <button class="btn btn-gradient-primary btn-lg w-100">
                                Register as Job Seeker
                                <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </form>

                    </div>
                </div>

                <p class="text-center text-light-50 mt-4">
                    Already have an account?
                    <a asp-page="./Login" class="fw-semibold login-link">Log in</a>
                </p>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .auth-page {
        position: relative;
        min-height: 90vh;
        overflow: hidden;
        background: linear-gradient(160deg, #05070f 0%, #0b1330 45%, #101a3d 75%, #05070f 100%);
    }

    .glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.35;
        pointer-events: none;
    }

    .glow-1 {
        width: 500px;
        height: 500px;
        background: #2b5cff;
        top: -150px;
        left: -100px;
    }

    .glow-2 {
        width: 450px;
        height: 450px;
        background: #1e3a8a;
        bottom: -180px;
        right: -120px;
    }

    .eyebrow-badge {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #cfd8ff;
        font-size: 0.85rem;
        font-weight: 500;
        backdrop-filter: blur(6px);
    }

        .eyebrow-badge i {
            color: #6d8cff;
        }

    .text-light-50 {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    .auth-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.035);
        backdrop-filter: blur(16px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
    }

    .dark-input {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        color: #fff !important;
    }

        .dark-input:focus {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border-color: #3b6dff !important;
            box-shadow: 0 0 0 0.2rem rgba(59, 109, 255, 0.25) !important;
        }

        .dark-input::placeholder {
            color: transparent;
        }

    .form-floating > label {
        color: rgba(255, 255, 255, 0.55);
    }

    .form-floating > .dark-input:focus ~ label,
    .form-floating > .dark-input:not(:placeholder-shown) ~ label {
        color: #8ba4ff;
    }

    .dark-input:-webkit-autofill {
        -webkit-box-shadow: 0 0 0 1000px rgba(20, 28, 60, 0.9) inset !important;
        -webkit-text-fill-color: #fff !important;
    }

    .login-link {
        color: #8ba4ff;
        text-decoration: none;
    }

        .login-link:hover {
            color: #b6c6ff;
        }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #3b6dff 0%, #1a3aad 100%);
        border: none;
        color: #fff;
        font-weight: 600;
        transition: filter 0.2s ease, transform 0.2s ease;
    }

        .btn-gradient-primary:hover {
            filter: brightness(1.15);
            color: #fff;
            transform: translateY(-2px);
        }
</style>