@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="auth-page">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <div class="container position-relative py-5">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">

                <div class="text-center mb-4">
                    <span class="badge rounded-pill eyebrow-badge px-3 py-2 mb-3">
                        <i class="bi bi-shield-lock me-1"></i> Secure Login
                    </span>
                    <h1 class="fw-bold text-white display-6">Welcome Back</h1>
                    <p class="text-light-50">Log in to continue to your dashboard.</p>
                </div>

                <div class="card auth-card">
                    <div class="card-body p-4 p-md-5">

                        <form id="account" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control dark-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                <label asp-for="Input.Email">Email</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control dark-input" autocomplete="current-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.Password">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="Input.RememberMe" />
                                    <label class="form-check-label text-light-50" asp-for="Input.RememberMe">
                                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                                    </label>
                                </div>
                                <a id="forgot-password" asp-page="./ForgotPassword" class="small login-link">Forgot password?</a>
                            </div>

                            <button id="login-submit" type="submit" class="btn btn-gradient-primary btn-lg w-100">
                                Log in
                                <i class="bi bi-arrow-right ms-1"></i>
                            </button>

                            <p class="text-center text-light-50 mt-3 mb-0 small">
                                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="login-link">Resend email confirmation</a>
                            </p>
                        </form>

                        @{
                            if ((Model.ExternalLogins?.Count ?? 0) > 0)
                            {
                                <div class="divider-text my-4"><span>or continue with</span></div>

                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                    <div class="d-grid gap-2">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn btn-outline-light-glass" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                                @provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }

                    </div>
                </div>

                <p class="text-center text-light-50 mt-4">
                    Don't have an account?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold login-link">Register here</a>
                </p>

            </div>
        </div>
    </div>
</div>

<style>
    .auth-page {
        position: relative;
        min-height: 90vh;
        overflow: hidden;
        background: linear-gradient(160deg, #05070f 0%, #0b1330 45%, #101a3d 75%, #05070f 100%);
    }

    .glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.35;
        pointer-events: none;
    }

    .glow-1 {
        width: 500px;
        height: 500px;
        background: #2b5cff;
        top: -150px;
        left: -100px;
    }

    .glow-2 {
        width: 450px;
        height: 450px;
        background: #1e3a8a;
        bottom: -180px;
        right: -120px;
    }

    .eyebrow-badge {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #cfd8ff;
        font-size: 0.85rem;
        font-weight: 500;
        backdrop-filter: blur(6px);
    }

        .eyebrow-badge i {
            color: #6d8cff;
        }

    .text-light-50 {
        color: rgba(255, 255, 255, 0.65) !important;
    }

    .auth-card {
        border-radius: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.035);
        backdrop-filter: blur(16px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);
    }

    /* Floating label inputs restyled for dark background */
    .dark-input {
        background-color: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        color: #fff !important;
    }

        .dark-input:focus {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border-color: #3b6dff !important;
            box-shadow: 0 0 0 0.2rem rgba(59, 109, 255, 0.25) !important;
        }

        .dark-input::placeholder {
            color: transparent;
        }

    .form-floating > label {
        color: rgba(255, 255, 255, 0.55);
    }

    .form-floating > .dark-input:focus ~ label,
    .form-floating > .dark-input:not(:placeholder-shown) ~ label {
        color: #8ba4ff;
    }
    /* autofill fix */
    .dark-input:-webkit-autofill {
        -webkit-box-shadow: 0 0 0 1000px rgba(20, 28, 60, 0.9) inset !important;
        -webkit-text-fill-color: #fff !important;
    }

    .form-check-input {
        background-color: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.25);
    }

        .form-check-input:checked {
            background-color: #3b6dff;
            border-color: #3b6dff;
        }

    .login-link {
        color: #8ba4ff;
        text-decoration: none;
    }

        .login-link:hover {
            color: #b6c6ff;
        }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #3b6dff 0%, #1a3aad 100%);
        border: none;
        color: #fff;
        font-weight: 600;
        transition: filter 0.2s ease, transform 0.2s ease;
    }

        .btn-gradient-primary:hover {
            filter: brightness(1.15);
            color: #fff;
            transform: translateY(-2px);
        }

    .btn-outline-light-glass {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff;
        font-weight: 500;
        transition: background 0.2s ease, transform 0.2s ease;
    }

        .btn-outline-light-glass:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            transform: translateY(-2px);
        }

    .divider-text {
        display: flex;
        align-items: center;
        text-align: center;
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.85rem;
    }

        .divider-text::before,
        .divider-text::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .divider-text span {
            padding: 0 0.75rem;
        }
</style>